generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id                       String            @id @default(cuid())
  pipedriveOrgId           Int               @unique
  chargeoverCustomerId     String?
  organizationName         String
  brandName                String?
  accountStatus            String
  accountManager           String?
  launchSpecialist         String?
  writer                   String?
  dealType                 String?
  engagementType           String?
  monthlyRetainer          Decimal?          @db.Decimal(10, 2)
  setupFee                 Decimal?          @db.Decimal(10, 2)
  financeNotes             String?
  wonTime                  DateTime?
  kickoffCall              DateTime?
  actualLaunchDate         DateTime?
  lastSyncedAt             DateTime          @default(now())
  createdAt                DateTime          @default(now())
  updatedAt                DateTime
  pilotRolloverEndDate     DateTime?
  postPilotExtendedEndDate DateTime?
  stripeCustomerId         String?
  billingProcessor         BillingProcessor?
  flags                    Flag[]
  payments                 Payment[]
  subscriptions            Subscription[]

  @@index([accountStatus])
  @@index([chargeoverCustomerId])
  @@index([billingProcessor])
  @@index([stripeCustomerId])
}

model Subscription {
  id                     String           @id @default(cuid())
  clientId               String
  externalSubscriptionId String           @unique
  status                 String
  amount                 Decimal          @db.Decimal(10, 2)
  startDate              DateTime?
  endDate                DateTime?
  lineItems              Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime
  billingProcessor       BillingProcessor @default(CHARGEOVER)
  client                 Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@index([billingProcessor])
}

model Payment {
  id                String           @id @default(cuid())
  clientId          String
  externalPaymentId String           @unique
  amount            Decimal          @db.Decimal(10, 2)
  paidDate          DateTime?
  status            String
  invoiceId         String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  billingProcessor  BillingProcessor @default(CHARGEOVER)
  statusNormalized  PaymentStatus    @default(UNKNOWN)
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([paidDate])
  @@index([billingProcessor])
}

model Flag {
  id          String     @id @default(cuid())
  clientId    String
  flagType    FlagType
  severity    Severity
  message     String
  detectedAt  DateTime   @default(now())
  dismissedAt DateTime?
  dismissedBy String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  FlagNote    FlagNote[]

  @@index([clientId])
  @@index([flagType])
  @@index([dismissedAt])
}

model SyncLog {
  id                         String    @id @default(cuid())
  startedAt                  DateTime  @default(now())
  completedAt                DateTime?
  status                     String
  pipedriveRecordsProcessed  Int       @default(0)
  chargeoverRecordsProcessed Int       @default(0)
  errors                     Json?
  stripeRecordsProcessed     Int       @default(0)

  @@index([startedAt])
}

model FlagNote {
  id        String   @id
  flagId    String
  body      String
  createdAt DateTime @default(now())
  Flag      Flag     @relation(fields: [flagId], references: [id], onDelete: Cascade)

  @@index([flagId])
}

model ClientNote {
  id              String    @id @default(cuid())
  clientId        String    @unique
  note            String
  updatedAt       DateTime  @updatedAt
  updatedBy       String
  reviewedByAdmin Boolean   @default(false)
  reviewedAt      DateTime?
}

enum FlagType {
  MISSING_SUBSCRIPTION
  ORPHAN_BILLING
  AMOUNT_MISMATCH
  DUPLICATE_SUBSCRIPTION
  MISSED_PAYMENT
  MISSING_SETUP_FEE
  MISSING_RETAINER_FIELD
  MISSING_CHARGEOVER_ID
  AMOUNT_OUTLIER
  SUSPENDED_SUBSCRIPTION
  MISSING_BILLING_ID
  MIXED_PROCESSOR_BILLING
  DUAL_BILLING_ID_SET
  PENDING_UPFRONT_CHARGE
  SILENT_FAILED_CHARGE
}

enum Severity {
  info
  warn
  error
}

enum BillingProcessor {
  CHARGEOVER
  STRIPE
}

enum PaymentStatus {
  SUCCESS
  PENDING
  FAILED
  UNKNOWN
}
